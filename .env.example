# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Browserless (managed Chromium — free tier: 6hrs/month)
# Sign up at https://browserless.io
BROWSERLESS_TOKEN=your-browserless-token

# Google PageSpeed Insights (free, 25k req/day)
# Get key at https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=AIza...

# Adyntel — primary ad intelligence (adyntel.com)
# Start free: 50 credits, no card. $44/mo for 5,000 credits.
# https://app.adyntel.com/login → Integrations → API Key
ADYNTEL_API_KEY=
ADYNTEL_EMAIL=you@company.com
# Set to False in production. When True + no API key → uses dummy data for POC testing.
ADYNTEL_DUMMY_MODE=True

# Meta Ad Library (legacy fallback — free)
# https://developers.facebook.com/docs/marketing-api/reference/ads-archive
META_AD_LIBRARY_TOKEN=EAA...

# Runtime
ENV=dev
AUDIT_CACHE_TTL_DAYS=30
LOG_LEVEL=INFO
